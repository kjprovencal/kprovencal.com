# Copy to your environment or systemd unit. Do not commit real secrets.

# At least 32 random bytes (e.g. openssl rand -base64 32)
SESSION_SECRET=

# Output of: go run ./cmd/hashpassword 'your-password'
ADMIN_PASSWORD_BCRYPT=

# Optional: default ./data/badger
# BADGER_PATH=data/badger

# Optional: default :8080
# LISTEN_ADDR=:8080

# Optional: slog level — debug, info (default), warn, error
# LOG_LEVEL=info

# Browser origin allowed to call the API (required when the static site and API differ, e.g. api subdomain).
# Dev: Vite dev server. Prod: main site origin (https://www.example.com), not the api host.
# CORS_ORIGIN=http://127.0.0.1:5173

# Cloudflare Turnstile secret (server-side). If unset, wedding RSVP accepts submissions without Turnstile (dev only).
# TURNSTILE_SECRET_KEY=

# When the API sits behind a trusted reverse proxy, set so Turnstile siteverify uses the first X-Forwarded-For hop as remoteip.
# TRUST_PROXY=1

# Set production so session cookies are Secure (HTTPS only)
# APP_ENV=production

# Optional: admin session length in hours (default 12, max 720)
# ADMIN_SESSION_HOURS=12
