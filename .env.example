# Public site key for Cloudflare Turnstile (wedding RSVP). Safe to expose in the browser.
# https://developers.cloudflare.com/turnstile/get-started/
# VITE_TURNSTILE_SITE_KEY=

# Production: Go API on its own host (no trailing slash). Leave unset locally so /api is proxied by Vite.
# VITE_PUBLIC_API_URL=https://api.example.com
